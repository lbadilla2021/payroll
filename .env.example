DATABASE_URL=postgresql+psycopg2://payroll:payroll@db:5432/payroll
ENVIRONMENT=development
JWT_SECRET=replace-with-very-strong-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ISSUER=payroll-api
JWT_AUDIENCE=payroll-web
ACCESS_TOKEN_MINUTES=10
REFRESH_TOKEN_DAYS=7
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ABSOLUTE_TIMEOUT_MINUTES=10080
PASSWORD_RESET_TOKEN_MINUTES=15
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
PASSWORD_RESET_REQUESTS_PER_HOUR=5
PASSWORD_MIN_LENGTH=12
ALLOW_GLOBAL_EMAIL_UNIQUENESS=false
BLOCKLIST_PATH=app/security/password_blocklist.txt
CORS_ALLOWED_ORIGINS=http://localhost:8080
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
APP_BASE_URL=http://localhost:8080
ENABLE_PASSWORD_RECOVERY=true
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=mailhog
SMTP_PASSWORD=mailhog
SMTP_FROM=no-reply@payroll.local
SMTP_FROM_NAME=Payroll Security
SMTP_USE_TLS=false
SUPERADMIN_EMAIL=superadmin@payroll.local
SUPERADMIN_PASSWORD=change-this-in-production
POSTGRES_DB=payroll
POSTGRES_USER=payroll
POSTGRES_PASSWORD=payroll
